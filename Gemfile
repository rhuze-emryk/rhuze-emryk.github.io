source "https://rubygems.org"

# Core dependencies
gem "github-pages", group: :jekyll_plugins
gem "jekyll", "~> 3.9.3"

# Required for newer Ruby versions
gem "webrick" 
gem "csv"
gem "base64"
gem "logger"

# For SASS processing
gem "sass-embedded", "~> 1.85"

# Markdown processor
gem "kramdown-parser-gfm"

# Theme
gem "jekyll-theme-basically-basic"

# Jekyll plugins
group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-paginate" 
  gem "jekyll-sitemap"
  gem "jekyll-seo-tag"
end
